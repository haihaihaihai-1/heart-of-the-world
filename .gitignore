# ============================================================
# .gitignore — Git 忽略文件配置
# ------------------------------------------------------------
# 这里列出的文件/文件夹不会被 git 跟踪和提交。
# 保护令牌、节省空间、避免提交构建产物。
# ============================================================

# ---------- 依赖目录（体积巨大，不应提交）----------
node_modules/
.pnp
.pnp.js

# ---------- 构建产物（可重新生成）----------
dist/
dist-electron/
build/
out/

# ---------- 包管理器日志 ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json.bak

# ---------- 敏感信息（绝对不能提交！）----------
# 任何包含 token / 密钥 / 凭据的文件
.env
.env.local
.env.*.local
*.secret
*.key
*.pem
**/.mcp.json
.workbuddy/

# ---------- 编辑器/IDE 配置 ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------- 操作系统文件 ----------
*.tmp
*.temp
*.log

# ---------- Electron 打包输出 ----------
release/
*.exe
*.dmg
*.AppImage
*.snap

# ---------- 缓存 ----------
.cache/
.parcel-cache/
.vite/
.eslintcache
